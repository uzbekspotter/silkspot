# ══════════════════════════════════════════════
# SILKSPOT — Environment Variables
# Скопируй в .env и заполни значения
# ══════════════════════════════════════════════

# ── Supabase (база данных + авторизация) ──────
# Settings → API → Project URL
VITE_SUPABASE_URL=https://ВАШ_ПРОЕКТ.supabase.co

# Settings → API → anon public key
VITE_SUPABASE_ANON_KEY=eyJ...ВАШ_КЛЮЧ

# ── Supabase (server scripts, seed/import) ───────────────
# Settings → API Keys → Publishable and secret API keys (recommended)
# SUPABASE_SECRET_KEY=sb_secret_...
# Legacy fallback: SUPABASE_SERVICE_ROLE_KEY (JWT)
SUPABASE_URL=https://ВАШ_ПРОЕКТ.supabase.co
SUPABASE_SECRET_KEY=sb_secret_ВАШ_КЛЮЧ
SUPABASE_SERVICE_ROLE_KEY=eyJ...SERVICE_ROLE

# Импорт аэропортов (OurAirports)
# ONLY_WITH_CODES=1  → импортировать только строки с IATA/ICAO
# INCLUDE_SMALL=1    → включить small_airport
ONLY_WITH_CODES=1
INCLUDE_SMALL=1

# ── Cloudflare R2 (хранилище фото) ────────────
# R2 → Bucket → Settings → Public URL
# Выглядит как: https://pub-xxxxx.r2.dev
VITE_R2_PUBLIC_URL=https://pub-XXXXX.r2.dev

# Метрики R2 в Moderation Center → Platform Stats (Vercel /api/r2-metrics)
# Хватает VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY (как на фронте); service role не нужен.
# API Token: Cloudflare → My Profile → API Tokens → Account → R2 Storage → Read
# CLOUDFLARE_API_TOKEN=
# R2_ACCOUNT_ID= (как для presign)
# Опционально: «потолок» в ГБ для отображения «осталось» (сам R2 без жёсткого лимита — биллинг по факту)
# R2_STORAGE_CAP_GB=10

# URL твоего Cloudflare Worker (для presigned URLs)
# Выглядит как: https://silkspot-upload.ТВОЙ_АКК.workers.dev
VITE_WORKER_URL=https://silkspot-upload.ТВОЙ_АКК.workers.dev

# ── App ───────────────────────────────────────
VITE_APP_URL=http://localhost:3000

# ── Telegram (moderation alerts, server-only on Vercel) ──
# Create a bot via @BotFather, get chat_id (user DM or group; for groups add bot and use getUpdates).
# TELEGRAM_APP_URL = public site URL used in the “Open Moderation Center” link (defaults to production).
# TELEGRAM_WEBHOOK_SECRET = random string; same value must be set in Supabase Database Webhook header.
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_IDS=-1001234567890
# TELEGRAM_APP_URL=https://silkspot.vercel.app
# TELEGRAM_WEBHOOK_SECRET=your-long-random-secret
